#!/usr/bin/env bash
set -euo pipefail

# Re-run when the declarative Neovim plugin inputs change:
#   lazy.lua:       {{ include "dot_config/nvim/lua/config/lazy.lua" | sha256sum }}
#   mason.lua:      {{ include "dot_config/nvim/lua/plugins/mason.lua" | sha256sum }}
#   lazy-lock.json: {{ include "dot_config/nvim/lazy-lock.json" | sha256sum }}

command -v nvim >/dev/null 2>&1 || {
  echo "chezmoi: nvim not found; skipping Neovim sync"
  exit 0
}

echo "chezmoi: syncing Lazy.nvim plugins and Mason tools"

lua_file="$(mktemp)"
trap 'rm -f "$lua_file"' EXIT

cat >"$lua_file" <<'LUA'
local Config = require("lazy.core.config")
local Plugin = require("lazy.core.plugin")

local spec = Config.plugins["mason.nvim"]
local opts = spec and Plugin.values(spec, "opts", false) or {}
local seen = {}
local tools = {}

for _, tool in ipairs(opts.ensure_installed or {}) do
  if not seen[tool] then
    seen[tool] = true
    tools[#tools + 1] = tool
  end
end

if #tools > 0 then
  vim.opt.rtp:prepend(vim.fn.stdpath("data") .. "/lazy/mason.nvim")
  require("mason").setup({})
  require("mason.api.command").MasonInstall(tools, {})
end
LUA

nvim --headless "+Lazy! restore" "+luafile $lua_file" +qa

echo "chezmoi: Neovim sync complete"
