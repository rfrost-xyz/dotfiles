{{- $role := get . "role" | default "desktop" -}}
# Runtime/state files — regenerated locally, never tracked
.claude.json
.p4trust
# Local per-machine secrets sourced by the shell (e.g. OP_SERVICE_ACCOUNT_TOKEN).
# Never tracked — lives only on the box, filled in by hand.
.config/bash/envs/local
# Pi auth — contains API keys / OAuth tokens, never track
.pi/agent/auth.json
.ssh/known_hosts
.ssh/known_hosts.old
# LazyVim/Mason: declare the *set* in lua (lazy.lua imports + plugins/mason.lua);
# let neovim own the actual installs + versions. These are neovim-managed state:
.config/nvim/lazyvim.json
.config/nvim/lazy-lock.json
# Active nvim colorscheme. Runtime state, never tracked: on the desktop omarchy
# owns it (symlink → current theme); on omaterm the theme-set hook syncs it in.
.config/nvim/lua/plugins/theme.lua
# piedpi is its own git repo now (~/.pi/agent/extensions/piedpi) — managed
# there, not via chezmoi.
.pi/agent/extensions/piedpi
.pi/agent/extensions/piedpi/**
# pi-ux retired — fully replaced by piedpi, deleted on disk.
.pi/agent/extensions/pi-ux
.pi/agent/extensions/pi-ux/**

{{- if ne $role "headless" }}
# Desktop: omarchy owns the nvim theme (theme.lua symlink → current theme), so
# the headless-only live theme-watcher must not land on the laptop.
.config/nvim/lua/plugins/omaterm-theme-watch.lua
# Desktop signs via the 1Password SSH agent (op-ssh-sign); the on-disk signing
# key is a headless-only fallback and must never land on the laptop.
.ssh/git_signing_key
.ssh/git_signing_key.pub
{{- end }}

{{- if eq $role "headless" }}
# Omaterm/headless: keep the terminal override layer, leave desktop/base files alone.
# NB: .bashrc is deliberately NOT ignored — it's the portable entrypoint that
# sources whichever base exists (omarchy or omadots' ~/.config/shell/all) and then
# the personal layer. omadots' own .bashrc has no hook for ~/.config/bash, so
# chezmoi must own .bashrc for the override layer to load at all.
.config/alacritty
.config/ghostty
.config/hypr
.config/omarchy
.config/waybar
.local/share/omarchy

# Laptop-only tools and P4 files.
.local/bin/parsec-manage
.local/bin/p4client
.p4enviro
.p4ignore
.config/bash/functions/p4_wrapper.sh
.config/lazyjira/auth.json
.ssh/fnox_anton
{{- end }}
