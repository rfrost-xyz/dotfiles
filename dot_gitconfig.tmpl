{{- $role := get . "role" | default "desktop" -}}

[user]
  name = Richard Frost
  email = richard.frost@squintopera.com
{{- if ne $role "headless" }}
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJwnn397qQDmlEN6xMTZ5OxxRBjVOq16FgU1F0GCcGL1
{{- else }}
  signingkey = {{ .chezmoi.homeDir }}/.ssh/git_signing_key.pub
{{- end }}
[init]
  defaultBranch = main
[core]
  editor = nvim
  longpaths = true
  autocrlf = input
[gpg]
  format = ssh
[commit]
  gpgsign = true
[tag]
  gpgsign = true
[push]
  followTags = true
  autoSetupRemote = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[alias]
  who = shortlog -sn --all --no-merges
[fetch]
  prune = true
[pull]
	rebase = true
[credential "https://git.squintopera.com"]
	helper =
	helper = !/usr/bin/glab auth git-credential
{{- if eq $role "headless" }}
# Headless has no 1Password SSH agent / desktop app, so GitHub auth is HTTPS via
# the gh CLI token rather than SSH.
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
{{- end }}
[gpg "ssh"]
{{- if eq $role "headless" }}
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
{{- else }}
	allowedSignersFile = /home/rfrost/.ssh/allowed_signers
{{- end }}
