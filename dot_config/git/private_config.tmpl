[user]
	name = Richard Frost
	email = richard.frost@squintopera.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJwnn397qQDmlEN6xMTZ5OxxRBjVOq16FgU1F0GCcGL1
[commit]
	gpgsign = true
[pull]
	rebase = true
[init]
	defaultBranch = main
[{{ .chezmoi.config.gpg.command }}]
	format = ssh
[{{ .chezmoi.config.gpg.command }} "ssh"]
	program = {{ .chezmoi.pathSeparator }}opt{{ .chezmoi.pathSeparator }}1Password{{ .chezmoi.pathSeparator }}{{ .chezmoi.config.onepassword.command }}-ssh-sign
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[filter "lfs"]
	clean = {{ .chezmoi.config.git.command }}-lfs clean -- %f
	smudge = {{ .chezmoi.config.git.command }}-lfs smudge -- %f
	process = {{ .chezmoi.config.git.command }}-lfs filter-process
	required = true
