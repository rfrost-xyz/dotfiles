#!/usr/bin/env bash
set -euo pipefail

command -v nvim >/dev/null 2>&1 || {
  echo "nvim-sync: nvim not found"
  exit 1
}

command -v chezmoi >/dev/null 2>&1 || {
  echo "nvim-sync: chezmoi not found"
  exit 1
}

echo "nvim-sync: restoring Lazy.nvim plugins and Mason tools"

lua_file="$(mktemp)"
trap 'rm -f "$lua_file"' EXIT

cat >"$lua_file" <<'LUA'
local Config = require("lazy.core.config")
local Plugin = require("lazy.core.plugin")

local spec = Config.plugins["mason.nvim"]
local opts = spec and Plugin.values(spec, "opts", false) or {}
local seen = {}
local tools = {}

for _, tool in ipairs(opts.ensure_installed or {}) do
  if not seen[tool] then
    seen[tool] = true
    tools[#tools + 1] = tool
  end
end

if #tools > 0 then
  vim.opt.rtp:prepend(vim.fn.stdpath("data") .. "/lazy/mason.nvim")
  require("mason").setup({})
  require("mason.api.command").MasonInstall(tools, {})
end
LUA

nvim --headless "+Lazy! restore" "+luafile $lua_file" +qa

# Lazy may touch the lockfile while installing/restoring. Keep the managed
# lockfile authoritative so `chezmoi status` stays clean after sync.
chezmoi apply --force --include files --exclude scripts ~/.config/nvim/lazy-lock.json

# Clean up artifacts from the removed chezmoi run-script approach.
rm -f "$HOME/.chezmoiscripts/20-nvim-sync.sh" "$HOME/20-nvim-sync.sh"
rmdir "$HOME/.chezmoiscripts" 2>/dev/null || true

echo "nvim-sync: complete"
