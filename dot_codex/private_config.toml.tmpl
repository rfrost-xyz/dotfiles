[tui]
status_line = ["model-with-reasoning", "five-hour-limit", "weekly-limit", "context-used", "context-window-size", "used-tokens", "total-input-tokens", "total-output-tokens", "task-progress", "branch-changes", "{{ .chezmoi.config.git.command }}-branch", "run-state"]
status_line_use_colors = true
pet = "fireball"

[tui.model_availability_nux]
"gpt-5.5" = 4

[features]
hooks = true
memories = true
terminal_resize_reflow = true
goals = true
prevent_idle_sleep = true

[mcp_servers.atlassian-squintopera]
url = "https{{ .chezmoi.pathListSeparator }}{{ .chezmoi.pathSeparator }}{{ .chezmoi.pathSeparator }}mcp.atlassian.com{{ .chezmoi.pathSeparator }}v1{{ .chezmoi.pathSeparator }}mcp"

[mcp_servers.atlassian-journey]
url = "https{{ .chezmoi.pathListSeparator }}{{ .chezmoi.pathSeparator }}{{ .chezmoi.pathSeparator }}mcp.atlassian.com{{ .chezmoi.pathSeparator }}v1{{ .chezmoi.pathSeparator }}mcp"

[notice]
fast_default_opt_out = true
