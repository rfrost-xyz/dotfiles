model = "gpt-5.5"
model_reasoning_effort = "medium"
approvals_reviewer = "guardian_subagent"
personality = "pragmatic"
[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}dev{{ .chezmoi.pathSeparator }}journey-io-pipeline"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Projects{{ .chezmoi.pathSeparator }}journey-io-pipeline"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}.pi"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}.pi{{ .chezmoi.pathSeparator }}agent{{ .chezmoi.pathSeparator }}extensions{{ .chezmoi.pathSeparator }}piedpi"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Projects{{ .chezmoi.pathSeparator }}engineering-docs"]
trust_level = "trusted"

[projects."{{ .chezmoi.commandDir }}{{ .chezmoi.pathSeparator }}.agents{{ .chezmoi.pathSeparator }}skills{{ .chezmoi.pathSeparator }}qiddiya-spatial-merge"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Documents{{ .chezmoi.pathSeparator }}Personal"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Projects{{ .chezmoi.pathSeparator }}squint-fighter"]
trust_level = "trusted"

[projects."{{ .chezmoi.commandDir }}"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Projects{{ .chezmoi.pathSeparator }}middleout"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}agent-usage-report{{ .chezmoi.pathSeparator }}sessionscope"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Projects{{ .chezmoi.pathSeparator }}anton"]
trust_level = "trusted"

[projects."{{ .chezmoi.destDir }}{{ .chezmoi.pathSeparator }}Projects{{ .chezmoi.pathSeparator }}timesheet"]
